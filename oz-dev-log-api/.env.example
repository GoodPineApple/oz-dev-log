PORT=3000

# true면 MongoDB 연결 없이 mock-data로 응답 (프론트만 돌릴 때)
# USE_MOCK_DATA=true

# MongoDB Atlas (또는 로컬 mongodb://...) 연결 문자열
# MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority
MONGODB_URI=

# Mongoose 앱 이름 (Atlas 클러스터 로그용, 선택)
# MONGODB_APP_NAME=oz-dev-log-api

# 프로덕션 등: 허용할 프론트 Origin을 콤마로 구분 (NODE_ENV=production 일 때 필수에 가깝게 사용)
# 로컬 개발: NODE_ENV가 production이 아니면 localhost / 127.0.0.1 / ::1 의 임의 포트도 허용됩니다.
# CORS_ORIGIN=https://app.example.com,https://www.example.com
