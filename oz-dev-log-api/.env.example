PORT=3000

# true면 MySQL 연결 없이 mock-data로 응답 (프론트만 돌릴 때)
# USE_MOCK_DATA=true

# MySQL (Sequelize) — 로컬 예시
DB_HOST=localhost
DB_PORT=3306
DB_NAME=oz_dev_log
DB_USER=root
DB_PASSWORD=

# SQL 로그 출력 (디버그 시 true)
# DB_LOGGING=true

# 개발용 테이블 생성·변경 (프로덕션은 마이그레이션 권장)
# DB_SYNC=true
# 기존 테이블 컬럼 맞추기 (주의: 데이터 손상 가능)
# DB_SYNC_ALTER=true

# 프로덕션 등: 허용할 프론트 Origin을 콤마로 구분 (NODE_ENV=production 일 때 필수에 가깝게 사용)
# 로컬 개발: NODE_ENV가 production이 아니면 localhost / 127.0.0.1 / ::1 의 임의 포트도 허용됩니다.
# CORS_ORIGIN=https://app.example.com,https://www.example.com