# ===================================================================
# oz-dev-log-api 환경변수
# 이 파일을 복사해 `.env` 로 저장한 뒤 값을 채워 사용하세요.
#   cp .env.example .env
# `.env` 는 절대 커밋하지 마세요(루트 .gitignore 가 이미 막아둡니다).
# ===================================================================

# 메인 API 백엔드 — 기본 포트는 3000
PORT=3000

# -------------------------------------------------------------------
# MySQL 접속 정보
# -------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=oz_dev_log_api
DB_USER=root
DB_PASSWORD=

# SQL 로그 출력 (디버그 시 true)
# DB_LOGGING=true

# 개발용 테이블 자동 생성 (true 권장 — 데모 환경)
DB_SYNC=true
# 기존 테이블 컬럼 맞추기 (필드를 추가했을 때 활성화).
# Attachment 에 file_path 컬럼이 추가되었으므로, 기존 DB가 있다면 한 번 true 로 기동.
# DB_SYNC_ALTER=true

# 첫 실행 시 시드 데이터를 채워넣을지 (true 권장 — 빈 DB 일 때만 동작)
SEED_ON_BOOT=true

# -------------------------------------------------------------------
# 인증 (JWT / bcrypt)
# -------------------------------------------------------------------
# JWT 서명 비밀키. 운영 환경에서는 절대 노출되지 않도록 한다.
JWT_SECRET=dev-secret-change-me
# 토큰 만료. zeit/ms 문법 ("10m", "1h", "7d") 또는 숫자(초).
JWT_EXPIRES_IN=1h

# bcrypt cost. 데모는 10이면 충분.
BCRYPT_ROUNDS=10

# ===================================================================
# 파일 업로드 저장소 (Firebase Storage)
# -------------------------------------------------------------------
# 아래 4개 키를 "모두" 채우면 Firebase Storage 가 활성화됩니다.
# 한 개라도 비어 있으면 자동으로 로컬 디스크(public/uploads/) 폴백으로 동작합니다.
# 서버 부팅 로그에 어느 드라이버가 선택됐는지 표시됩니다:
#   [api] 파일 저장소 드라이버: firebase   ← 모두 채워졌을 때
#   [api] 파일 저장소 드라이버: local      ← 비어 있을 때
#
# ┌─ 발급 절차 ───────────────────────────────────────────────────────
# │ 1) https://console.firebase.google.com 에서 프로젝트 생성 (또는 기존 프로젝트 선택)
# │
# │ 2) 좌측 메뉴 → Build → Storage → "Get started" 로 Storage 활성화
# │    ※ 보안 규칙은 데모에선 test mode(누구나 read) 로 시작해도 무방하나,
# │       이 서버는 어드민 SDK 로 업로드하고 download token URL 을 발급하므로
# │       보안 규칙과 무관하게 동작합니다.
# │
# │ 3) 좌측 톱니바퀴(Project settings) → "Service accounts" 탭
# │    → "Generate new private key" → JSON 다운로드
# │    ※ 이 JSON 은 Storage 전체에 쓰기 가능한 강력한 키입니다. 절대 공유/커밋 금지.
# │
# │ 4) 다운로드한 JSON 에서 다음 세 필드를 옮겨 적기:
# │      "project_id"    → FIREBASE_PROJECT_ID
# │      "client_email"  → FIREBASE_CLIENT_EMAIL
# │      "private_key"   → FIREBASE_PRIVATE_KEY  (아래 주의사항 참고)
# │
# │ 5) Storage 페이지 상단의 "gs://..." 경로에서 버킷 이름을 확인해
# │    FIREBASE_STORAGE_BUCKET 에 넣습니다 (gs:// 접두사는 제외).
# └───────────────────────────────────────────────────────────────────
#
# ┌─ private key 입력 시 주의 ───────────────────────────────────────
# │ JSON 안의 private_key 값은 다음과 같은 한 줄 문자열입니다:
# │   "-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
# │
# │ .env 에 넣을 때는 양 끝의 따옴표(")까지 그대로 복사해 큰따옴표로 감쌉니다.
# │   FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# │
# │ 줄바꿈은 실제 개행이 아니라 두 글자(\n) 그대로 두세요.
# │ 서버(config/storage.js)가 .replace(/\\n/g, "\n") 으로 진짜 개행으로 바꿔 줍니다.
# └───────────────────────────────────────────────────────────────────
# ===================================================================

# 예: "oz-dev-log-12345"
FIREBASE_PROJECT_ID=

# 예: "firebase-adminsdk-xxxxx@<project-id>.iam.gserviceaccount.com"
FIREBASE_CLIENT_EMAIL=

# 큰따옴표로 감싸고 줄바꿈은 \n 그대로. 예:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# Firebase 콘솔의 Storage 페이지 상단에 표시되는 gs://<bucket> 의 <bucket> 부분.
# 보통 "<project-id>.appspot.com" 또는 "<project-id>.firebasestorage.app" 형태.
FIREBASE_STORAGE_BUCKET=

# -------------------------------------------------------------------
# CORS
# -------------------------------------------------------------------
# 콤마 구분 추가 CORS Origin. NODE_ENV=production이 아니면 localhost는 자동 허용.
# CORS_ORIGIN=https://app.example.com
