# 두 백엔드 origin (프로토콜 + 호스트 + 포트, 끝 슬래시 없음).
# 비워 두면 Vite 프록시 경로(/sequelize/*, /mongoose/*)로 라우팅된다.
VITE_API_URL=http://localhost:3000
VITE_SEQUELIZE_API_URL=http://localhost:3001
VITE_MONGOOSE_API_URL=http://localhost:3002

# 기본 백엔드 — 사용자가 UI에서 변경하기 전 처음 사용할 값.
# 'sequelize' | 'mongoose'
VITE_DEFAULT_BACKEND=sequelize
