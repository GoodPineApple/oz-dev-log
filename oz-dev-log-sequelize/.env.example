# Sequelize 백엔드 (MySQL) — 기본 포트는 3001
PORT=3001

# MySQL 접속 정보
DB_HOST=localhost
DB_PORT=3306
DB_NAME=oz_dev_log_sequelize
DB_USER=root
DB_PASSWORD=

# SQL 로그 출력 (디버그 시 true)
# DB_LOGGING=true

# 개발용 테이블 자동 생성 (true 권장 — 데모 환경)
DB_SYNC=true
# 기존 테이블 컬럼 맞추기 (주의: 데이터 손상 가능)
# DB_SYNC_ALTER=true

# 첫 실행 시 시드 데이터를 채워넣을지 (true 권장 — 빈 DB 일 때만 동작)
SEED_ON_BOOT=true

# 콤마 구분 추가 CORS Origin. NODE_ENV=production이 아니면 localhost는 자동 허용.
# CORS_ORIGIN=https://app.example.com
