{
  "name": "oz-dev-log",
  "private": true,
  "description": "DevLog monorepo — app(Vite/React) + 메인 API(JWT) + 비교용 백엔드(Sequelize/Mongoose)",
  "workspaces": [
    "oz-dev-log-app",
    "oz-dev-log-api",
    "oz-dev-log-sequelize",
    "oz-dev-log-mongoose",
    "oz-dev-log-next"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,seq,mongo,app -c cyan,blue,green,magenta \"npm run dev -w oz-dev-log-api\" \"npm run dev -w oz-dev-log-sequelize\" \"npm run dev -w oz-dev-log-mongoose\" \"npm run dev -w oz-dev-log-app\"",
    "dev:app": "npm run dev -w oz-dev-log-app",
    "dev:api": "npm run dev -w oz-dev-log-api",
    "dev:sequelize": "npm run dev -w oz-dev-log-sequelize",
    "dev:mongoose": "npm run dev -w oz-dev-log-mongoose",
    "dev:next": "npm run dev -w oz-dev-log-next",
    "build:next": "npm run build -w oz-dev-log-next",
    "build": "npm run build -w oz-dev-log-app",
    "lint": "npm run lint -w oz-dev-log-app",
    "start:api": "npm run start -w oz-dev-log-api",
    "start:sequelize": "npm run start -w oz-dev-log-sequelize",
    "start:mongoose": "npm run start -w oz-dev-log-mongoose"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "overrides": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
