# Mongoose 백엔드 (MongoDB) — 기본 포트는 3002
PORT=3002

# MongoDB 접속 URI (Atlas 또는 로컬 mongod)
# 로컬 예: mongodb://127.0.0.1:27017/oz_dev_log_mongoose
# Atlas 예: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/oz_dev_log_mongoose
MONGODB_URI=mongodb://127.0.0.1:27017/oz_dev_log_mongoose

# 첫 실행 시 시드 데이터를 채워넣을지 (true 권장 — 빈 DB 일 때만 동작)
SEED_ON_BOOT=true

# Mongoose 디버그 로깅
# MONGOOSE_DEBUG=true

# 콤마 구분 추가 CORS Origin. NODE_ENV=production이 아니면 localhost는 자동 허용.
# CORS_ORIGIN=https://app.example.com
